{
  "name": "@mulmocast/deck",
  "version": "1.1.0",
  "description": "MulmoCast deck DSL: JSON-described semantic slide layouts (stats, comparison, timeline, ...) rendered to Tailwind-based HTML",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src test",
    "format": "prettier --write '{src,test}/**/*.ts'",
    "test": "tsx --test ./test/**/test_*.ts",
    "prepublishOnly": "yarn run build"
  },
  "files": [
    "lib"
  ],
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mulmocast",
    "deck",
    "slide",
    "dsl",
    "tailwind",
    "presentation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/receptron/mulmocast-deck.git"
  },
  "bugs": {
    "url": "https://github.com/receptron/mulmocast-deck/issues"
  },
  "homepage": "https://github.com/receptron/mulmocast-deck#readme",
  "engines": {
    "node": ">=22.0.0"
  }
}
